# NAS 备份配置示例
# 复制此文件为 .env.nas 并填写实际配置
# .env.nas 已在 .gitignore 中排除，不会提交到 git

# NAS 连接配置
NAS_IP=192.168.1.185
NAS_SHARE=backup
NAS_USER=admin
NAS_PASSWORD=your_password_here

# 挂载点（可选，默认 /Volumes/nas_backup）
NAS_MOUNT_POINT=/Volumes/nas_backup

# 备份保留天数（可选，默认保留所有）
# 设置为 30 表示保留最近 30 天的备份
BACKUP_RETENTION_DAYS=30
